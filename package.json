{
  "name": "gptlite",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm -r --sort build",
    "dev": "pnpm -r --parallel --filter @gptlite/server --filter @gptlite/web dev",
    "typecheck": "pnpm -r --sort typecheck",
    "start": "node apps/server/dist/index.js"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
