OPENAI_API_KEY=sk-your-key
JWT_SECRET=replace-with-a-long-random-secret
OPENAI_BASE_URL=http://new-api:3000/v1

# Optional: use separate OpenAI-compatible endpoints for chat/thinking and image.
# Empty values fall back to OPENAI_BASE_URL / OPENAI_API_KEY.
CHAT_API_BASE_URL=
CHAT_API_KEY=
IMAGE_API_PROVIDER=openai
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
IMAGE_API_POLL_INTERVAL_MS=2500
IMAGE_API_TIMEOUT_MS=300000

# For the GRSAI GPT Image channel:
# IMAGE_API_PROVIDER=grsai
# IMAGE_API_BASE_URL=https://grsaiapi.com
# IMAGE_API_KEY=your-grsai-api-key
# DEFAULT_IMAGE_MODEL=gpt-image-2

# Public origin used when GRSAI needs to fetch uploaded reference images.
# Example: https://gpt.einzieg.io
PUBLIC_APP_URL=

DEFAULT_CHAT_MODEL=gpt-5.4-mini
DEFAULT_THINKING_MODEL=gpt-5.4
DEFAULT_IMAGE_MODEL=gpt-image-2

# Set to true only when the app is served over HTTPS.
COOKIE_SECURE=false

# Optional: create the first admin automatically on first boot.
ADMIN_USERNAME=
ADMIN_PASSWORD=
